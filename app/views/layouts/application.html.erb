<!DOCTYPE html>
<html>
  <head>
    <title>LegalOps</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
  </head>

  <body style="margin: 0;">
    <% flash.each do |type, message| %>
      <div style="margin: 12px; padding: 10px; border-radius: 8px; background: <%= type.to_s == 'alert' ? '#fee2e2' : '#dcfce7' %>; color: #0f172a;">
        <%= message %>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
