<header class="page-header">
  <div>
    <h2>Clients</h2>
    <p class="subtitle">Maintain contact records and activity status for all clients.</p>
  </div>
  <%= link_to 'New Client', new_client_path, class: 'button' %>
</header>

<section class="card">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr>
          <td><%= link_to client.name, client_path(client) %></td>
          <td><%= client.email %></td>
          <td><%= client.phone %></td>
          <td>
            <span class="badge <%= 'active' if client.active? %>">
              <%= client.active? ? 'Active' : 'Inactive' %>
            </span>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
