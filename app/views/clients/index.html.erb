<section class="section-header">
  <h2>Clients</h2>
  <%= link_to 'New Client', new_client_path, class: 'button' %>
</section>

<section class="card">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr>
          <td><%= link_to client.name, client_path(client) %></td>
          <td><%= client.email %></td>
          <td><%= client.phone %></td>
          <td><%= client.active? ? 'Active' : 'Inactive' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
