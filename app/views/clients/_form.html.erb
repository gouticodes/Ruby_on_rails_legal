<%= render 'shared/errors', object: @client %>

<%= form_with model: @client do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>
  <div>
    <%= f.label :email %>
    <%= f.email_field :email %>
  </div>
  <div>
    <%= f.label :phone %>
    <%= f.text_field :phone %>
  </div>
  <div>
    <%= f.label :active %>
    <%= f.check_box :active %>
  </div>

  <%= f.submit class: 'button' %>
<% end %>
