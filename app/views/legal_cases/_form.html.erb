<%= render 'shared/errors', object: @legal_case %>

<%= form_with model: @legal_case do |f| %>
  <div>
    <%= f.label :client_id, 'Client' %>
    <%= f.collection_select :client_id, Client.order(:name), :id, :name %>
  </div>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>
  <div>
    <%= f.label :case_number %>
    <%= f.text_field :case_number %>
  </div>
  <div>
    <%= f.label :jurisdiction %>
    <%= f.text_field :jurisdiction %>
  </div>
  <div>
    <%= f.label :status %>
    <%= f.select :status, LegalCase::STATUSES.map { |s| [s.humanize, s] } %>
  </div>
  <div>
    <%= f.label :summary %>
    <%= f.text_area :summary, rows: 4 %>
  </div>

  <%= f.submit class: 'button' %>
<% end %>
